generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/libs/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id                String             @id @default(nanoid())
  name              String
  email             String             @unique
  hashedPassword    String
  role              Roles              @default(USER)
  avatarUrl         String?
  provider          Providers?
  googleId          String?            @unique
  verified          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  ratings           Ratings[]
  verificationCodes VerificationCodes?
}

model VerificationCodes {
  id         String   @id @default(nanoid())
  code       String   @unique @default(nanoid())
  userId     String   @unique
  used       Boolean  @default(false)
  validUntil DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  outings   Outings[]
}

model Outings {
  id         String     @id @default(cuid())
  title      String
  content    String
  price      Int
  slug       String     @unique
  public     Audience
  categoryId Int
  locationId Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  event     Event?
  openHours  OpenHour[]
  location   Location   @relation(fields: [locationId], references: [id])
  category   Category   @relation(fields: [categoryId], references: [id])
  park       Park?
  photos     Photo[]
  ratings    Ratings[]
  trail      Trail?
}

model Trail {
  id         String   @id @default(cuid())
  outingId   String   @unique
  difficulty String
  duration   Int
  distance   Float
  roundTrip  Boolean
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  outing     Outings  @relation(fields: [outingId], references: [id], onDelete: Cascade)
}

model Park {
  id              String   @id @default(cuid())
  outingId        String   @unique
  biodiversity    String
  maximumCapacity Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  outing          Outings  @relation(fields: [outingId], references: [id], onDelete: Cascade)
}

model Event {
  id              String    @id @default(cuid())
  outingId        String    @unique
  maximumCapacity Int
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  outing          Outings   @relation(fields: [outingId], references: [id], onDelete: Cascade)
}

model Photo {
  id        String   @id @default(cuid())
  alt       String
  url       String
  outingId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  outing    Outings  @relation(fields: [outingId], references: [id], onDelete: Cascade)
}

model OpenHour {
  id        String   @id @default(uuid())
  dayOfWeek Int
  openTime  String
  closeTime String
  outingId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  outing    Outings  @relation(fields: [outingId], references: [id], onDelete: Cascade)
}

model Ratings {
  id        String   @id @default(cuid())
  comment   String?
  rating    Int
  userId    String
  outingId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  outing    Outings  @relation(fields: [outingId], references: [id], onDelete: Cascade)
  user      Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model City {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  locations Location[]
}

model Location {
  id        Int       @id @default(autoincrement())
  latitude  Float
  longitude Float
  cityId    Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  city      City      @relation(fields: [cityId], references: [id])
  outings   Outings[]
}

enum Providers {
  GOOGLE
}

enum Roles {
  USER
  ADMIN
}

enum Audience {
  ALL
  PLUS18
  PLUS16
  PLUS12
}
